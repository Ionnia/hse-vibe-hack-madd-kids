# Database
DATABASE_URL=postgresql+asyncpg://tutor:tutor@localhost:5432/tutor
DATABASE_URL_SYNC=postgresql://tutor:tutor@localhost:5432/tutor

# Telegram Bot
TELEGRAM_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LLM Provider (stub | openai | ollama)
LLM_PROVIDER=stub
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=http://localhost:11434

# Storage (local | s3)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# OCR backend (stub | tesseract | google)
OCR_BACKEND=stub

# Transcription backend (stub | whisper | deepgram)
TRANSCRIPTION_BACKEND=stub

# Web Search backend (stub | duckduckgo)
WEB_SEARCH_BACKEND=duckduckgo
WEB_SEARCH_RESULTS_COUNT=5
